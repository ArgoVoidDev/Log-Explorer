// Core identity. Domain modules reference User via userId FKs; add back-relations
// on this model when a module ships (e.g. catalogOrders CatalogOrder[]).

model User {
  id              String    @id @default(cuid())
  name            String
  phone           String    @unique
  email           String?   @unique
  passwordHash    String
  avatarUrl       String?
  phoneVerifiedAt DateTime?
  role            UserRole  @default(CUSTOMER)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  loginOtps           LoginOtp[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  catalogOrders       CatalogOrder[]
  couponUsages        CouponUsage[]
  savedAddresses      SavedAddress[]
}
