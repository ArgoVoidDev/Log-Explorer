// Cross-cutting security primitives shared by all modules.

model RateLimitBucket {
  id          String    @id @default(cuid())
  key         String    @unique
  count       Int       @default(0)
  windowStart DateTime
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([lockedUntil])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  resource  String
  details   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([resource])
}
