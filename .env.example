# Database (required in production)
DATABASE_URL="postgresql://user:password@localhost:5432/argocore"

# Seed (optional)
# SEED_ADMIN_PHONE="09120000000"
# SEED_ADMIN_PASSWORD="admin123"

# Auth — NextAuth v5 (AUTH_SECRET required ≥32 chars in production)
AUTH_SECRET="dev-only-change-me-to-a-long-random-string"
AUTH_URL="http://localhost:3000"

# Public site origin (required in production — payment callbacks / OG / JSON-LD)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: CAPTCHA on auth flows (bypassed when secret unset)
# NEXT_PUBLIC_CAPTCHA_SITE_KEY=""
# CAPTCHA_SECRET_KEY=""
# CAPTCHA_PROVIDER="turnstile"

# Optional: cron endpoints (rate-limit GC + expire orders). Required for /api/cron/*.
# CRON_SECRET=""

# Optional: Arvan Object Storage (S3-compatible). Without these, uploads use public/uploads/.
# ARVAN_ENDPOINT=""
# ARVAN_ACCESS_KEY=""
# ARVAN_SECRET_KEY=""
# ARVAN_BUCKET=""
# ARVAN_CDN_DOMAIN=""

# Optional: Zarinpal (ecommerce module)
# ZARINPAL_MERCHANT_ID=""
# ZARINPAL_SANDBOX="true"

# Optional: Kavenegar SMS
# KAVENEGAR_API_KEY=""
# KAVENEGAR_OTP_TEMPLATE=""
# KAVENEGAR_ORDER_SUCCESS_TEMPLATE=""
# KAVENEGAR_ORDER_SHIPPED_TEMPLATE=""

# Active domain modules (comma-separated). Controls admin view registration.
ACTIVE_MODULES="ecommerce,saas"

# Portfolio module (public)
# NEXT_PUBLIC_PORTFOLIO_NAME="Argo"
# NEXT_PUBLIC_PORTFOLIO_TAGLINE="Selected work across product, brand, and digital craft."
# NEXT_PUBLIC_PORTFOLIO_ROLE="Designer & maker"
# NEXT_PUBLIC_PORTFOLIO_ABOUT="I build focused digital experiences..."
# NEXT_PUBLIC_PORTFOLIO_INSTAGRAM_URL="https://instagram.com/yourhandle"
# NEXT_PUBLIC_PORTFOLIO_TELEGRAM_URL="https://t.me/yourhandle"

# CI / smoke builds only — skips Zod env validation (never use in real deploys)
# SKIP_ENV_VALIDATION="1"
